{
  "name": "jahiacom",
  "version": "1.0.4-SNAPSHOT",
  "type": "module",
  "files": [
    "dist",
    "src/**/*.cnd",
    "settings",
    "static"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && run build:lottie && run package",
    "build:lottie": "rolldown @lottiefiles/dotlottie-wc -mo dist/assets/lottie.js",
    "clean": "rm -rf dist/",
    "deploy": "jahia-deploy",
    "format": "prettier --write --list-different .",
    "lint": "eslint . && stylelint 'src/**/*.css'",
    "fix": "eslint . --fix && stylelint 'src/**/*.css' --fix && run format",
    "package": "yarn pack --out dist/package.tgz",
    "dev": "vite build --watch",
    "watch": "run dev",
    "watch:callback": "run build:lottie && run package && run deploy"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.6",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@lottiefiles/dotlottie-wc": "^0.9.4",
    "clsx": "^2.1.1",
    "modern-normalize": "^3.0.1",
    "pretty-bytes": "^7.1.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@chachalog/types": "^0.5.0",
    "@eslint-react/eslint-plugin": "^2.3.9",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@iconify-json/ri": "^1.2.6",
    "@iconify-json/simple-icons": "^1.2.60",
    "@jahia/javascript-modules-library": "^1.2.0",
    "@jahia/vite-plugin": "^1.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "i18next": "^25.6.3",
    "prettier": "^3.7.1",
    "react-i18next": "^16.3.5",
    "rolldown": "^1.0.0-rc.6",
    "stylelint": "^16.26.1",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "unocss": "^66.5.9",
    "vite": "^7.2.4",
    "vite-css-modules": "^1.11.1"
  },
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0"
  },
  "jahia": {
    "module-dependencies": "default",
    "module-type": "templatesSet",
    "server": "dist/server/index.js",
    "static-resources": "/dist/client,/dist/assets,/locales,/images,/icons"
  }
}
