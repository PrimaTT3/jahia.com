[jahiacom:hero] > jnt:content, jmix:droppableContent, mix:title
 - subtitle (string, textarea) i18n
 - image (weakreference, picker[type='image']) i18n mandatory < jmix:image
 - j:linkType (string, choicelist[linkTypeInitializer]) mandatory
 - ctaLabel (string) i18n
 - background (string, choicelist) = 'plusses' itemtype=layout < 'plusses', 'stripes'
