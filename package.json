{
  "name": "jahiacom",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "src/**/*.cnd",
    "settings",
    "static"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && run package",
    "clean": "rm -rf dist/",
    "deploy": "jahia-deploy",
    "format": "prettier --write --list-different .",
    "lint": "eslint .",
    "package": "yarn pack --out dist/package.tgz",
    "dev": "vite build --watch",
    "watch": "run dev",
    "watch:callback": "run package && run deploy"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.2",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "modern-normalize": "^3.0.1",
    "pretty-bytes": "^6.1.1",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^1.47.2",
    "@eslint/compat": "^1.2.8",
    "@eslint/js": "^9.24.0",
    "@iconify-json/ri": "^1.2.5",
    "@jahia/javascript-modules-library": "^0.6.1",
    "@jahia/vite-plugin": "^0.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "i18next": "^23.16.8",
    "prettier": "^3.5.3",
    "react-i18next": "^15.4.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "typescript-plugin-css-modules": "^5.1.0",
    "unocss": "66.1.0-beta.10",
    "vite": "^6.2.6"
  },
  "packageManager": "yarn@4.7.0",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0"
  },
  "jahia": {
    "snapshot": true,
    "module-dependencies": "default",
    "module-type": "templatesSet",
    "server": "dist/server/index.js",
    "static-resources": "/dist,/locales,/images,/icons"
  }
}
