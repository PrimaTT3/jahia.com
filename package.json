{
  "name": "jahiacom",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "src/**/*.cnd",
    "settings",
    "static"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && run package",
    "clean": "rm -rf dist/",
    "deploy": "jahia-deploy",
    "format": "prettier --write --list-different .",
    "lint": "eslint . && stylelint 'src/**/*.css'",
    "package": "yarn pack --out dist/package.tgz",
    "dev": "vite build --watch",
    "watch": "run dev",
    "watch:callback": "run package && run deploy"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.5",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.6",
    "clsx": "^2.1.1",
    "modern-normalize": "^3.0.1",
    "pretty-bytes": "^7.0.0",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^1.52.3",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.32.0",
    "@iconify-json/ri": "^1.2.5",
    "@jahia/javascript-modules-library": "^0.8.0",
    "@jahia/vite-plugin": "^0.8.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "i18next": "^25.3.2",
    "prettier": "^3.6.2",
    "react-i18next": "^15.6.1",
    "stylelint": "^16.23.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.38.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "unocss": "^66.4.1",
    "vite": "^7.0.6",
    "vite-css-modules": "^1.9.2"
  },
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0"
  },
  "jahia": {
    "snapshot": true,
    "module-dependencies": "default",
    "module-type": "templatesSet",
    "server": "dist/server/index.js",
    "static-resources": "/dist/client,/dist/assets,/locales,/images,/icons"
  }
}
