<urlrewrite>
  <rule>
    <name>Display partners under the partners page</name>
    <from>^(.*)/find-a-partner/(?!main/)(.*)$</from>
    <to>$1/find-a-partner/main/section/content-stack/display-a-content-folder@/implementation-partners/$2</to>
  </rule>

  <outbound-rule>
    <name>Display partners under the partners page (outbound)</name>
    <from>^/cms/render/live/(.+)/find-a-partner/main/section/content-stack/display-a-content-folder%40/implementation-partners/(.+)$</from>
    <to>/cms/render/live/$1/find-a-partner/$2</to>
  </outbound-rule>
</urlrewrite>
