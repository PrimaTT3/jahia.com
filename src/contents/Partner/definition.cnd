[jahiacom:partner] > jnt:content, jahiacommix:content, mix:title, jmix:visibleInContentTree, jmix:mainResource
 - certification (string, choicelist[resourceBundle]) mandatory < silver, gold, diamond
 - countries (string, choicelist[country]) multiple mandatory
 - description (string, richtext) mandatory i18n
 - logo (weakreference, picker) < jmix:image
